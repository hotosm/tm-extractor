# Required: Raw Data API access token
RAWDATA_API_AUTH_TOKEN=replace_me

# Optional: required only for private Tasking Manager projects
# TASKING_MANAGER_API_KEY=Token your_tm_api_key

# Optional: Sentry error reporting (needs tm-extractor[sentry] extra)
# SENTRY_DSN=https://your-dsn@sentry.io/123

# Optional overrides
# RAW_DATA_API_BASE_URL=https://api-prod.raw-data.hotosm.org/v1
# TM_API_BASE_URL=https://tasking-manager-production-api.hotosm.org/api/v2
# CONFIG_JSON=/etc/tm-extractor/config.json
